#include "pass_input_state.h"

static uint8_t pass_selected_digit;
static uint16_t pass_digit[3];

main_state_t PassInputState_Loop()
{
    main_state_t nextMain = MAIN_STATE_PASS_INPUT;

    sub_state_pass_input_t subState = GetSubState();
    sub_state_pass_input_t nextSubState;

	switch(subState)
	{
		case SUB_STATE_PASS_INPUT_INIT:
			nextSubState = PassInputState_Init();
			break;

		case SUB_STATE_PASS_INPUT_PASS_WAIT:
			break;

		case SUB_STATE_PASS_INPUT_PASS_CHECK:
			nextSubState = PassInputState_PassCheck();
			break;

		case SUB_STATE_PASS_INPUT_PASS_SUCCESS:
			SetSubState(SUB_STATE_STANDBY_INIT);
			return MAIN_STATE_STANDBY;

		default:
	        nextSubState = SUB_STATE_PASS_INPUT_INIT;
	        break;
	}

	if(nextSubState != subState)
	{
		SetSubState(nextSubState);
	}

	return nextMain;
}


sub_state_pass_input_t PassInputState_Init()
{
	pass_digit[2] = 0;
	pass_digit[1] = 0;
	pass_digit[0] = 0;
	pass_selected_digit = 2;

	return SUB_STATE_PASS_INPUT_PASS_CHECK;
}

